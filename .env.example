# Illyrian Flash Liquidator environment template.
# Copy this file to `.env` for local runs, then fill in the secret values.
# For Render, add the secret values in the dashboard when prompted by render.yaml.

# Runtime
NODE_VERSION=20.11.1
CHAIN=POLYGON
DRY_RUN=true

# Liquidation thresholds
MIN_PROFIT_USD=0.3
MAX_GAS_USD=5
MIN_DEBT_USD=50
MAX_DEBT_USD=5000
WATCH_THRESHOLD=1.15
SLIPPAGE_PERCENT=1

# Feature flags
USE_MEV_PROTECTION=false
USE_MEMPOOL=true
USE_SUBGRAPH=true
USE_CACHE=true

# Dashboard
DASHBOARD_PORT=3001
DASHBOARD_TOKEN=

# Required secrets
PRIVATE_KEY=
POLYGON_RPC_URL=
POLYGON_WSS_URL=
POLYGON_CONTRACT_ADDRESS=
GRAPH_API_KEY=

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
