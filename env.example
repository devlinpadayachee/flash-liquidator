# ========================================================
# FLASH LIQUIDATOR - Zero-Capital Liquidation Bot
# ========================================================
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────
# CHAIN SELECTION
# ─────────────────────────────────────────────────────────
# Options: POLYGON, ARBITRUM, BASE, BSC, AVALANCHE
# RECOMMENDATION: Start with BASE - less competition!
CHAIN=BASE

# ─────────────────────────────────────────────────────────
# RPC PROVIDERS
# ─────────────────────────────────────────────────────────
# Get free RPC from: https://www.ankr.com/rpc/ or https://www.alchemy.com/
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_WSS_URL=wss://bsc-ws-node.nariox.org:443

POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WSS_URL=wss://polygon.drpc.org

ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WSS_URL=wss://arb1.arbitrum.io/ws

BASE_RPC_URL=https://mainnet.base.org
BASE_WSS_URL=wss://base.publicnode.com

AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WSS_URL=wss://api.avax.network/ext/bc/C/ws

# ─────────────────────────────────────────────────────────
# WALLET (REQUIRED)
# ─────────────────────────────────────────────────────────
# Your wallet private key (for gas fees only - needs ~$5)
# NEVER share this!
PRIVATE_KEY=your_private_key_here

# ─────────────────────────────────────────────────────────
# FLASH LIQUIDATOR CONTRACT
# ─────────────────────────────────────────────────────────
# Deploy first: npm run deploy:base (or deploy:polygon, etc)
# Then add the deployed address here
BSC_CONTRACT_ADDRESS=
POLYGON_CONTRACT_ADDRESS=
ARBITRUM_CONTRACT_ADDRESS=
BASE_CONTRACT_ADDRESS=
AVALANCHE_CONTRACT_ADDRESS=

# ─────────────────────────────────────────────────────────
# PROFIT SETTINGS - Target SMALL liquidations!
# ─────────────────────────────────────────────────────────
# This is your competitive advantage - big bots skip small positions

# Minimum profit to execute (USD)
MIN_PROFIT_USD=2

# Maximum gas to spend per liquidation (USD)
MAX_GAS_USD=5

# Minimum debt to liquidate (USD) - smaller = less competition
# Set to 10 to catch more small positions
MIN_DEBT_USD=10

# Maximum debt to liquidate (USD) - big bots target above this
# Set higher (50000) to catch more positions initially
MAX_DEBT_USD=50000

# Health factor threshold to start watching
# 1.15 = very risky (15% from liquidation) - few positions
# 1.50 = moderately risky - more positions to watch
# 2.00 = safe but watching - many positions
# RECOMMENDATION: Start with 1.50 to catch more opportunities
WATCH_THRESHOLD=1.50

# ─────────────────────────────────────────────────────────
# MEV PROTECTION - IMPORTANT!
# ─────────────────────────────────────────────────────────
# Enable to prevent frontrunning by other bots
# Submits transactions to private mempools
USE_MEV_PROTECTION=true

# Gas premium for priority (%)
GAS_PREMIUM_PERCENT=10

# ─────────────────────────────────────────────────────────
# SMART GAS BIDDING
# ─────────────────────────────────────────────────────────
# Max % of expected profit to spend on gas
MAX_GAS_PROFIT_PERCENT=30

# Minimum priority fee boost (gwei)
MIN_PRIORITY_BOOST=1

# Maximum priority fee (gwei)
MAX_PRIORITY_FEE=50

# Gas multiplier for urgent liquidations
URGENT_GAS_MULTIPLIER=1.5

# ─────────────────────────────────────────────────────────
# PRICE MONITORING
# ─────────────────────────────────────────────────────────
# Alert on price drops (liquidation opportunities!)
PRICE_DROP_ALERT=5

# How often to check prices (seconds)
PRICE_CHECK_INTERVAL=30

# ─────────────────────────────────────────────────────────
# TIMING
# ─────────────────────────────────────────────────────────
# How often to scan for new borrowers (seconds)
SCAN_INTERVAL=300

# How often to check health factors (seconds)
HEALTH_CHECK_INTERVAL=30

# How often to show status (seconds)
STATUS_INTERVAL=60

# Max borrowers to track (INCREASED for more opportunities!)
MAX_BORROWERS=5000

# Number of blocks to scan for new borrowers
BLOCK_SCAN_RANGE=2000

# Priority check count - how many riskiest positions to check every 5s
PRIORITY_CHECK_COUNT=75

# Watch threshold governs the 5s "hot list" (positions re-checked every cycle).
# Tighter (e.g. 1.08 = within 8% of liquidation) keeps the hot list focused and
# cuts RPC load; the rotation sweep below still covers the whole population, so
# nothing is missed. Loose values (1.5) flood the list and waste RPC.

# ROTATION_WINDOW: how many borrowers from the FULL population get re-priced
# each 5s priority cycle. This is what catches a healthy position that suddenly
# decays. Full sweep takes ~(population / window) cycles. Higher = faster
# coverage but more RPC; lower it if your RPC is rate-limited.
ROTATION_WINDOW=120

# Hours a liquidated/closed address stays blacklisted before it can be
# rediscovered (so an address that repays then re-borrows comes back).
CLOSED_TTL_HOURS=12

# ─────────────────────────────────────────────────────────
# MEMPOOL MONITORING (COMPETITIVE ADVANTAGE!)
# ─────────────────────────────────────────────────────────
# Watch for pending oracle price updates BEFORE they confirm
# This gives you the same speed as MEV bots!
#
# Requirements:
# - Paid RPC plan with mempool access (Alchemy, QuickNode, Infura)
# - Free RPCs DO NOT expose pending transactions
#
# Enable/disable mempool monitoring (requires WSS URL with mempool access)
USE_MEMPOOL=true

# If you have a premium RPC with mempool, set it here:
# Recommended providers with mempool:
# - Alchemy Growth ($49/mo): wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# - QuickNode ($49/mo): wss://xxx.quiknode.pro/YOUR_KEY
# - BloxRoute ($100+/mo): Best for MEV
#
# Free alternatives (limited mempool):
# - DRPC (some mempool): wss://polygon.drpc.org
# - Chainstack: Limited pending tx access

# ─────────────────────────────────────────────────────────
# RPC OPTIMIZATION (CRITICAL for reducing costs!)
# ─────────────────────────────────────────────────────────
# Multicall batch size - how many health checks per RPC call
# Higher = fewer RPC calls but larger responses
# 100 = check 100 users in 1 RPC call (vs 100 individual calls!)
MULTICALL_BATCH_SIZE=100

# Enable/disable caching (saves borrowers to disk, reduces startup time)
USE_CACHE=true

# Debug mode - shows why positions are filtered out
DEBUG_RANGES=true

# Max closed positions to keep in cache (prevents "closed" list from growing forever)
# Addresses older than this limit can be re-discovered if they borrow again
MAX_CLOSED_POSITIONS=5000

# Set to true to clear ALL closed positions on startup (use if cache is stale)
# This will make the bot re-check all previously closed addresses
CLEAR_CLOSED_CACHE=false

# ─────────────────────────────────────────────────────────
# SUBGRAPH (Borrower Discovery) - RECOMMENDED!
# ─────────────────────────────────────────────────────────
# Uses The Graph to find ALL borrowers (much better than RPC events)
# Free public endpoints included - no API key needed!
USE_SUBGRAPH=true

# The Graph API key for decentralized network (HIGHLY RECOMMENDED!)
# Without this: ~3-50 borrowers from recent blocks only
# With this: 5000+ borrowers from all time!
# Get FREE key at: https://thegraph.com/studio/ (takes 2 minutes)
GRAPH_API_KEY=your_api_key_here

# ─────────────────────────────────────────────────────────
# TELEGRAM ALERTS (Optional but recommended!)
# ─────────────────────────────────────────────────────────
# Get instant notifications on your phone!
# 1. Create a bot with @BotFather on Telegram
# 2. Get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────
# MODES
# ─────────────────────────────────────────────────────────
# Dry run mode (simulation only - no real trades)
# Start with true to test!
DRY_RUN=true

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────
# ADVANCED
# ─────────────────────────────────────────────────────────
# Slippage tolerance for swaps (%)
SLIPPAGE_PERCENT=1

# Show health factor table
SHOW_HEALTH_FACTORS=true

# Max positions to display in table
MAX_HEALTH_DISPLAY=15

# ─────────────────────────────────────────────────────────
# DASHBOARD (live web UI)
# ─────────────────────────────────────────────────────────
# Local port for the dashboard (ignored on Render, which injects PORT).
DASHBOARD_PORT=3001

# Optional: lock the dashboard behind a token. If set, the data API and live
# stream require it. STRONGLY recommended when hosting on a public URL.
# Open the dashboard at:  https://your-app.onrender.com/?token=YOUR_TOKEN
DASHBOARD_TOKEN=

# =========================================================
# QUICK START GUIDE:
# =========================================================
# 1. Copy this file to .env
# 2. Add your PRIVATE_KEY (needs ~$5 in native token for gas)
# 3. npm install
# 4. npm run compile
# 5. npm run deploy:base (or your chosen chain)
# 6. Copy deployed contract address to BASE_CONTRACT_ADDRESS
# 7. npm start (starts in DRY_RUN mode - safe!)
# 8. Set DRY_RUN=false when ready for live execution
#
# RECOMMENDED CHAINS (by competition level):
# - BASE:      LOW competition, 8% Moonwell bonus
# - ARBITRUM:  MEDIUM competition, 15% Radiant bonus!
# - POLYGON:   MEDIUM competition
# - AVALANCHE: MEDIUM competition, 8% Benqi bonus
# - BSC:       HIGH competition, 10% Venus bonus
# =========================================================

